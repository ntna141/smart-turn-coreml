            tensor<fp16, [1, 1, 1, 1]> logits_cast_fp16 = conv(bias = cls_fc2_bias_to_fp16, dilations = logits_dilations_0, groups = logits_groups_0, pad = logits_pad_0, pad_type = logits_pad_type_0, strides = logits_strides_0, weight = cls_fc2_weight_to_fp16, x = input_cast_fp16)[name = tensor<string, []>("logits_cast_fp16")];
