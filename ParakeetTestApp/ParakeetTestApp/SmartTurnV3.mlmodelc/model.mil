            tensor<fp16, [64, 256, 1, 1]> cls_fc1_weight_to_fp16 = const()[name = tensor<string, []>("cls_fc1_weight_to_fp16"), val = tensor<fp16, [64, 256, 1, 1]>(BLOBFILE(path = tensor<string, []>("@model_path/weights/weight.bin"), offset = tensor<uint64, []>(15975360)))];
            tensor<fp16, [64]> cls_fc1_bias_to_fp16 = const()[name = tensor<string, []>("cls_fc1_bias_to_fp16"), val = tensor<fp16, [64]>(BLOBFILE(path = tensor<string, []>("@model_path/weights/weight.bin"), offset = tensor<uint64, []>(16008192)))];
            tensor<fp16, [1, 64, 1, 1]> x_cast_fp16 = conv(bias = cls_fc1_bias_to_fp16, dilations = x_dilations_0, groups = x_groups_0, pad = x_pad_0, pad_type = x_pad_type_0, strides = x_strides_0, weight = cls_fc1_weight_to_fp16, x = input_43_cast_fp16)[name = tensor<string, []>("x_cast_fp16")];
